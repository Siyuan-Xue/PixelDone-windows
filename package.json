{
  "name": "pixeldone-windows",
  "version": "3.2.5",
  "description": "Rust-first Windows client for PixelDone",
  "type": "module",
  "private": true,
  "packageManager": "bun@1.3.14",
  "scripts": {
    "dev": "vite dev",
    "build": "svelte-kit sync && vite build",
    "build:e2e": "svelte-kit sync && vite build --mode e2e",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test": "svelte-kit sync && bun test",
    "e2e:binary": "tauri build --debug --no-bundle --config src-tauri/tauri.e2e.conf.json",
    "e2e": "bun run e2e:binary && wdio run wdio.conf.ts",
    "parity:report": "bun scripts/generate-parity-report.ts",
    "parity:check": "bun scripts/verify-parity.ts",
    "release:manifest": "bun scripts/generate-release-manifest.ts",
    "tauri": "tauri"
  },
  "license": "MIT",
  "overrides": {
    "@wdio/native-utils": "2.5.0"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.6",
    "@sveltejs/kit": "^2.9.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tauri-apps/cli": "^2",
    "@wdio/cli": "^9",
    "@wdio/local-runner": "^9",
    "@wdio/mocha-framework": "^9",
    "@wdio/spec-reporter": "^9",
    "@wdio/tauri-plugin": "^1.2.0",
    "@wdio/tauri-service": "^1.2.0",
    "svelte": "^5.56.4",
    "svelte-check": "^4.0.0",
    "typescript": "6.0.2",
    "vite": "^6.0.3",
    "webdriverio": "^9"
  }
}
