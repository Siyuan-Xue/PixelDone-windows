{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PixelDone",
  "version": "3.1.1",
  "mainBinaryName": "PixelDone",
  "identifier": "com.milesxue.pixeldone.windows",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "PixelDone",
        "width": 1180,
        "height": 780,
        "minWidth": 1000,
        "minHeight": 680,
        "center": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: http://asset.localhost blob: data:; style-src 'self' 'unsafe-inline'; connect-src ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis"],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["pixeldone-reminder"]
      }
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEE5RkYzNThCRjlGM0NCMjEKUldRaHkvUDVpelgvcVhvQVNFTmMzeHVDRmpVL2RZUGNoTXZwaEVxR21JOGEvNzBSWWIwYllEejcK",
      "endpoints": [
        "https://github.com/Siyuan-Xue/PixelDone-windows/releases/latest/download/latest.json",
        "https://gitee.com/milesxue/PixelDone-windows/releases/download/latest/latest.json"
      ]
    }
  }
}
